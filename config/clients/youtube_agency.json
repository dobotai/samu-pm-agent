{
  "client_name": "youtube_agency",
  "agent_type": "project_management",
  "system_prompt": "You are a powerful AI assistant with broad capabilities similar to Claude Code. You can read and write files, execute commands, search the web, and access Slack, Google Drive, and Airtable.\n\n## CONFIRMATION REQUIRED\nBefore making ANY changes (writing files, editing files, executing commands, sending messages), you MUST:\n1. Explain exactly what you're about to do\n2. Show the exact content/command\n3. Ask: 'Should I proceed with this change? (yes/no)'\n4. Wait for explicit 'yes' before executing\n\nRead-only operations (reading files, searching, listing) do NOT require confirmation.\n\nBe professional, thorough, and helpful. You have extensive capabilities - use them wisely.",

  "available_tools": [
    {
      "name": "read_file",
      "script": "execution/file_ops.py",
      "description": "Read the contents of a file. Returns line-numbered content.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "read"},
          "file_path": {"type": "string", "description": "Absolute or relative path to the file"},
          "offset": {"type": "number", "description": "Line number to start from (0-indexed)", "default": 0},
          "limit": {"type": "number", "description": "Number of lines to read", "default": 2000}
        },
        "required": ["action", "file_path"]
      }
    },
    {
      "name": "write_file",
      "script": "execution/file_ops.py",
      "description": "Write content to a file. Creates the file if it doesn't exist, overwrites if it does. REQUIRES CONFIRMATION.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "write"},
          "file_path": {"type": "string", "description": "Path to the file to write"},
          "content": {"type": "string", "description": "Content to write to the file"}
        },
        "required": ["action", "file_path", "content"]
      }
    },
    {
      "name": "edit_file",
      "script": "execution/file_ops.py",
      "description": "Edit a file by replacing specific text. REQUIRES CONFIRMATION.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "edit"},
          "file_path": {"type": "string", "description": "Path to the file to edit"},
          "old_string": {"type": "string", "description": "Text to find and replace"},
          "new_string": {"type": "string", "description": "Text to replace with"},
          "replace_all": {"type": "boolean", "description": "Replace all occurrences", "default": false}
        },
        "required": ["action", "file_path", "old_string", "new_string"]
      }
    },
    {
      "name": "list_directory",
      "script": "execution/file_ops.py",
      "description": "List files and directories in a path",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "list"},
          "dir_path": {"type": "string", "description": "Directory path to list", "default": "."},
          "pattern": {"type": "string", "description": "Optional filter pattern (e.g., *.py)"}
        },
        "required": ["action"]
      }
    },
    {
      "name": "execute_command",
      "script": "execution/bash_exec.py",
      "description": "Execute a shell/bash command. REQUIRES CONFIRMATION for any command that modifies state.",
      "input_schema": {
        "type": "object",
        "properties": {
          "command": {"type": "string", "description": "The command to execute"},
          "cwd": {"type": "string", "description": "Working directory for the command"},
          "timeout": {"type": "number", "description": "Timeout in seconds", "default": 120}
        },
        "required": ["command"]
      }
    },
    {
      "name": "glob_search",
      "script": "execution/search_tools.py",
      "description": "Find files matching a glob pattern (e.g., **/*.py, src/**/*.ts)",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "glob"},
          "pattern": {"type": "string", "description": "Glob pattern to match files"},
          "path": {"type": "string", "description": "Base path to search from", "default": "."},
          "max_results": {"type": "number", "description": "Maximum results to return", "default": 100}
        },
        "required": ["action", "pattern"]
      }
    },
    {
      "name": "grep_search",
      "script": "execution/search_tools.py",
      "description": "Search for a pattern in file contents (regex supported)",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "grep"},
          "pattern": {"type": "string", "description": "Regex pattern to search for"},
          "path": {"type": "string", "description": "File or directory to search in", "default": "."},
          "file_pattern": {"type": "string", "description": "Only search files matching this pattern (e.g., *.py)"},
          "case_insensitive": {"type": "boolean", "description": "Case insensitive search", "default": false},
          "context_lines": {"type": "number", "description": "Lines of context around matches", "default": 0}
        },
        "required": ["action", "pattern"]
      }
    },
    {
      "name": "web_fetch",
      "script": "execution/web_tools.py",
      "description": "Fetch and read content from a URL",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "fetch"},
          "url": {"type": "string", "description": "URL to fetch content from"}
        },
        "required": ["action", "url"]
      }
    },
    {
      "name": "web_search",
      "script": "execution/web_tools.py",
      "description": "Search the web using DuckDuckGo",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "search"},
          "query": {"type": "string", "description": "Search query"},
          "num_results": {"type": "number", "description": "Number of results to return", "default": 5}
        },
        "required": ["action", "query"]
      }
    },
    {
      "name": "slack_list_channels",
      "script": "execution/tools/slack_read.py",
      "description": "List all Slack channels in the workspace",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "list_channels"}
        },
        "required": ["action"]
      }
    },
    {
      "name": "slack_read_messages",
      "script": "execution/tools/slack_read.py",
      "description": "Read recent messages from a specific Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "read_messages"},
          "channel_id": {"type": "string", "description": "The Slack channel ID"},
          "limit": {"type": "number", "description": "Number of messages to retrieve", "default": 50}
        },
        "required": ["action", "channel_id"]
      }
    },
    {
      "name": "slack_search_messages",
      "script": "execution/tools/slack_read.py",
      "description": "Search for messages across all Slack channels",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "search_messages"},
          "query": {"type": "string", "description": "Search query"}
        },
        "required": ["action", "query"]
      }
    },
    {
      "name": "slack_list_users",
      "script": "execution/tools/slack_read.py",
      "description": "List all users in the Slack workspace",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "list_users"}
        },
        "required": ["action"]
      }
    },
    {
      "name": "slack_send_message",
      "script": "execution/tools/slack_write.py",
      "description": "Send a message to a Slack channel. REQUIRES CONFIRMATION.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "send_message"},
          "channel": {"type": "string", "description": "Channel ID or name"},
          "message": {"type": "string", "description": "Message text to send"}
        },
        "required": ["action", "channel", "message"]
      }
    },
    {
      "name": "slack_send_dm",
      "script": "execution/tools/slack_write.py",
      "description": "Send a direct message to a Slack user. REQUIRES CONFIRMATION.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "send_dm"},
          "user_identifier": {"type": "string", "description": "User email or Slack user ID"},
          "message": {"type": "string", "description": "Message text to send"}
        },
        "required": ["action", "user_identifier", "message"]
      }
    },
    {
      "name": "slack_reply_to_thread",
      "script": "execution/tools/slack_write.py",
      "description": "Reply to a message thread in Slack. REQUIRES CONFIRMATION.",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "reply_to_thread"},
          "channel": {"type": "string", "description": "Channel ID"},
          "thread_ts": {"type": "string", "description": "Timestamp of parent message"},
          "message": {"type": "string", "description": "Reply text"}
        },
        "required": ["action", "channel", "thread_ts", "message"]
      }
    },
    {
      "name": "slack_add_reaction",
      "script": "execution/tools/slack_write.py",
      "description": "Add an emoji reaction to a Slack message",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "add_reaction"},
          "channel": {"type": "string", "description": "Channel ID"},
          "timestamp": {"type": "string", "description": "Message timestamp"},
          "emoji": {"type": "string", "description": "Emoji name (e.g., thumbsup)"}
        },
        "required": ["action", "channel", "timestamp", "emoji"]
      }
    },
    {
      "name": "drive_list_files",
      "script": "execution/tools/drive_read.py",
      "description": "List files from Google Drive",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "list_files"},
          "folder_id": {"type": "string", "description": "Folder ID to list from"},
          "limit": {"type": "number", "default": 100}
        },
        "required": ["action"]
      }
    },
    {
      "name": "drive_search_files",
      "script": "execution/tools/drive_read.py",
      "description": "Search for files in Google Drive",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "search_files"},
          "query": {"type": "string", "description": "Search query"}
        },
        "required": ["action", "query"]
      }
    },
    {
      "name": "drive_get_file_info",
      "script": "execution/tools/drive_read.py",
      "description": "Get detailed info about a Drive file",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "get_file_info"},
          "file_id": {"type": "string", "description": "The file ID"}
        },
        "required": ["action", "file_id"]
      }
    },
    {
      "name": "drive_list_recent",
      "script": "execution/tools/drive_read.py",
      "description": "List recently modified Drive files",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "list_recent"},
          "limit": {"type": "number", "default": 20}
        },
        "required": ["action"]
      }
    },
    {
      "name": "airtable_list_records",
      "script": "execution/tools/airtable_read.py",
      "description": "List records from an Airtable table",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "list_records"},
          "base_id": {"type": "string"},
          "table_name": {"type": "string"},
          "limit": {"type": "number", "default": 100}
        },
        "required": ["action", "base_id", "table_name"]
      }
    },
    {
      "name": "airtable_get_record",
      "script": "execution/tools/airtable_read.py",
      "description": "Get a specific Airtable record",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "get_record"},
          "base_id": {"type": "string"},
          "table_name": {"type": "string"},
          "record_id": {"type": "string"}
        },
        "required": ["action", "base_id", "table_name", "record_id"]
      }
    },
    {
      "name": "airtable_search_records",
      "script": "execution/tools/airtable_read.py",
      "description": "Search Airtable records",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "search_records"},
          "base_id": {"type": "string"},
          "table_name": {"type": "string"},
          "field_name": {"type": "string"},
          "search_value": {"type": "string"}
        },
        "required": ["action", "base_id", "table_name", "field_name", "search_value"]
      }
    },
    {
      "name": "airtable_filter_records",
      "script": "execution/tools/airtable_read.py",
      "description": "Filter Airtable records with a formula",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "filter_records"},
          "base_id": {"type": "string"},
          "table_name": {"type": "string"},
          "filter_formula": {"type": "string", "description": "Airtable formula e.g. {Status}='Done'"}
        },
        "required": ["action", "base_id", "table_name", "filter_formula"]
      }
    },
    {
      "name": "airtable_list_bases",
      "script": "execution/tools/airtable_read.py",
      "description": "List all Airtable bases",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "list_bases"}
        },
        "required": ["action"]
      }
    },
    {
      "name": "airtable_get_table_schema",
      "script": "execution/tools/airtable_read.py",
      "description": "Get the schema of an Airtable table",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {"type": "string", "const": "get_table_schema"},
          "base_id": {"type": "string"},
          "table_name": {"type": "string"}
        },
        "required": ["action", "base_id", "table_name"]
      }
    }
  ],

  "constraints": [
    "CONFIRMATION REQUIRED: Always ask for confirmation before making any changes (write, edit, execute, send)",
    "Read-only operations do NOT require confirmation",
    "Show exactly what you're about to do before asking for confirmation",
    "Wait for explicit 'yes' before executing any modification",
    "Be thorough and use your full capabilities to help the user",
    "Explain your reasoning and approach",
    "If something fails, diagnose and suggest fixes"
  ],

  "output_destinations": {
    "reports_sheet": "",
    "notifications_email": "",
    "slack_webhook": ""
  }
}
