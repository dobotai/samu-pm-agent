{
  "client_name": "youtube_agency",
  "agent_type": "project_management",
  "system_prompt": "You are a project management assistant for a YouTube content agency. Help manage video projects, track content schedules, coordinate team tasks, and access information from Slack, Google Drive, and Airtable. Be professional, proactive, and detail-oriented. Always confirm before making significant changes to project data.",

  "available_tools": [
    {
      "name": "slack_list_channels",
      "script": "execution/tools/slack_read.py",
      "description": "List all Slack channels in the workspace",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["list_channels"],
            "default": "list_channels"
          }
        },
        "required": []
      }
    },
    {
      "name": "slack_read_messages",
      "script": "execution/tools/slack_read.py",
      "description": "Read recent messages from a specific Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["read_messages"],
            "default": "read_messages"
          },
          "channel_id": {
            "type": "string",
            "description": "The Slack channel ID to read messages from"
          },
          "limit": {
            "type": "number",
            "description": "Number of messages to retrieve (default: 50)",
            "default": 50
          }
        },
        "required": ["channel_id"]
      }
    },
    {
      "name": "slack_search_messages",
      "script": "execution/tools/slack_read.py",
      "description": "Search for messages across all Slack channels",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["search_messages"],
            "default": "search_messages"
          },
          "query": {
            "type": "string",
            "description": "Search query to find messages"
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "slack_list_users",
      "script": "execution/tools/slack_read.py",
      "description": "List all users in the Slack workspace",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["list_users"],
            "default": "list_users"
          }
        },
        "required": []
      }
    },
    {
      "name": "slack_send_message",
      "script": "execution/tools/slack_write.py",
      "description": "Send a message to a Slack channel",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["send_message"],
            "default": "send_message"
          },
          "channel": {
            "type": "string",
            "description": "Channel ID or channel name (e.g., #general)"
          },
          "message": {
            "type": "string",
            "description": "The message text to send"
          }
        },
        "required": ["channel", "message"]
      }
    },
    {
      "name": "slack_send_dm",
      "script": "execution/tools/slack_write.py",
      "description": "Send a direct message to a Slack user by email or user ID",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["send_dm"],
            "default": "send_dm"
          },
          "user_identifier": {
            "type": "string",
            "description": "User email (e.g., anna@company.com) or Slack user ID"
          },
          "message": {
            "type": "string",
            "description": "The message text to send"
          }
        },
        "required": ["user_identifier", "message"]
      }
    },
    {
      "name": "slack_reply_to_thread",
      "script": "execution/tools/slack_write.py",
      "description": "Reply to a message thread in Slack",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["reply_to_thread"],
            "default": "reply_to_thread"
          },
          "channel": {
            "type": "string",
            "description": "Channel ID where the thread exists"
          },
          "thread_ts": {
            "type": "string",
            "description": "Timestamp of the parent message"
          },
          "message": {
            "type": "string",
            "description": "The reply text to send"
          }
        },
        "required": ["channel", "thread_ts", "message"]
      }
    },
    {
      "name": "slack_add_reaction",
      "script": "execution/tools/slack_write.py",
      "description": "Add an emoji reaction to a Slack message",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["add_reaction"],
            "default": "add_reaction"
          },
          "channel": {
            "type": "string",
            "description": "Channel ID where the message exists"
          },
          "timestamp": {
            "type": "string",
            "description": "Timestamp of the message to react to"
          },
          "emoji": {
            "type": "string",
            "description": "Emoji name (e.g., thumbsup, eyes, checkmark)"
          }
        },
        "required": ["channel", "timestamp", "emoji"]
      }
