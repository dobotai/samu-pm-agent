# PM Agent Configuration Template
# DO NOT fill in this file directly - use configure.bat instead
# This file is for reference only

# ============================================
# CORE CREDENTIALS (REQUIRED)
# ============================================

# Anthropic API Key (from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Client Authentication (auto-generated by configure.bat)
CLIENT_API_KEY=auto_generated_by_wizard
CLIENT_NAME=youtube_agency

# ============================================
# SLACK INTEGRATION (REQUIRED)
# ============================================

# Slack Bot Token (from https://api.slack.com/apps)
# Required scopes: channels:read, channels:history, users:read, chat:write, reactions:write
SLACK_BOT_TOKEN=xoxb-YOUR_TOKEN_HERE

# Slack User Token (optional - for cross-workspace search)
SLACK_USER_TOKEN=xoxp-YOUR_TOKEN_HERE

# ============================================
# AIRTABLE INTEGRATION (REQUIRED)
# ============================================

# Airtable Personal Access Token (from https://airtable.com/create/tokens)
AIRTABLE_API_KEY=patYOUR_TOKEN_HERE

# Airtable Base ID (from your Airtable URL)
AIRTABLE_BASE_ID=appYOUR_BASE_ID_HERE

# ============================================
# GOOGLE DRIVE (OPTIONAL)
# ============================================

# Path to Google service account JSON file
# Leave empty if not using Google Drive
GOOGLE_CREDENTIALS_JSON=

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# Slack Webhook URL (for notifications)
SLACK_WEBHOOK_URL=

# SendGrid API Key (for email)
SENDGRID_API_KEY=

# Google OAuth Token (if using OAuth instead of service account)
GOOGLE_TOKEN_JSON=

# ============================================
# AUTOMATION SCHEDULER
# ============================================

# Simon's Slack User ID (find via Slack profile > "Copy member ID")
SIMON_SLACK_USER_ID=U0XXXXXXXXX

# Model for summary generation (default: claude-sonnet-4-20250514)
SUMMARY_MODEL=claude-sonnet-4-20250514
